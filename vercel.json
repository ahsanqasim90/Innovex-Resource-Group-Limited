{
  "version": 2,
  "installCommand": "npm install && npm install --prefix client",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "client/dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "innovexresourcegroup.co.uk"
        }
      ],
      "destination": "https://www.innovexresourcegroup.co.uk/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/interviews/reminders/run",
      "schedule": "0 8 * * *"
    }
  ]
}
