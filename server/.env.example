PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/innovex_resource_group
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=admin@innovexresourcegroup.co.uk
ADMIN_PASSWORD=ChangeMe123!
CONTACT_TO_EMAIL=info@innovexresourcegroup.co.uk
MAIL_FROM=info@innovexresourcegroup.co.uk
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=info@innovexresourcegroup.co.uk
SMTP_PASS=your-email-password-or-app-password
IMAP_HOST=imap.hostinger.com
IMAP_PORT=993
IMAP_SECURE=true

# CRM sender mailboxes
# Info mailbox can reuse SMTP_* above, or you can override it with SMTP_INFO_*.
SMTP_INFO_ADDRESS=info@innovexresourcegroup.co.uk
SMTP_INFO_LABEL=Info mailbox
SMTP_INFO_NAME=Innovex Resource Group Limited

# Mark mailbox appears in CRM only when these SMTP_MARK values are configured.
SMTP_MARK_ADDRESS=mark.harrison@innovexresourcegroup.co.uk
SMTP_MARK_LABEL=Mark Harrison
SMTP_MARK_NAME=Mark Harrison
SMTP_MARK_SMTP_HOST=smtp.hostinger.com
SMTP_MARK_SMTP_PORT=465
SMTP_MARK_SMTP_SECURE=true
SMTP_MARK_SMTP_USER=mark.harrison@innovexresourcegroup.co.uk
SMTP_MARK_SMTP_PASS=your-mark-mailbox-password
# Optional per-mailbox IMAP overrides; otherwise the shared IMAP_* values above are used.
# SMTP_MARK_IMAP_HOST=imap.hostinger.com
# SMTP_MARK_IMAP_PORT=993
# SMTP_MARK_IMAP_SECURE=true

# Optional: add more CRM sender mailboxes later without code changes.
# SMTP_EXTRA_ACCOUNTS=[{"address":"custom@innovexresourcegroup.co.uk","label":"Custom mailbox","name":"Innovex Team","host":"smtp.hostinger.com","port":465,"secure":true,"user":"custom@innovexresourcegroup.co.uk","pass":"mailbox-password"}]
INTERVIEW_REMINDER_HOUR=8
CRON_SECRET=replace-with-a-long-random-secret-for-vercel-cron

# Yay.com dialler integration
YAY_API_BASE_URL=https://api.yay.com
YAY_AUTH_RESELLER=your-yay-reseller-token
YAY_AUTH_USER=admin
YAY_AUTH_PASSWORD=your-yay-api-password
YAY_USER_AGENT=InnovexResourceGroupCRM/1.0
YAY_CLICK_TO_CALL_PATH=/call
YAY_AGENT_EXTENSION=1001
YAY_HUNT_GROUP_EXTENSION=2001
YAY_OUTBOUND_NUMBERS=+443300435830,+442922520491
